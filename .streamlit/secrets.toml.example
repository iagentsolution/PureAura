# ═══════════════════════════════════════════════════════════
# PureAura — Secrets de Deploy (Streamlit Cloud)
# ═══════════════════════════════════════════════════════════
#
# INSTRUCCIONES:
# 1. Copiá este archivo como ".streamlit/secrets.toml"
# 2. Completá los valores reales
# 3. NUNCA commits el archivo secrets.toml real
#
# En Streamlit Cloud podés configurar estos secretos
# directamente en: Settings → Secrets
# No necesitás subir el archivo.
#
# ═══════════════════════════════════════════════════════════

# ── Groq AI ──────────────────────────────────────────────
# Obtené tu API key en: https://console.groq.com/keys
GROQ_API_KEY = "gsk_tu-api-key-aqui"

# ── Modelo (opcional, tiene default) ────────────────────
GROQ_MODEL = "llama-3.3-70b-versatile"
GROQ_TEMPERATURE = "0.7"
GROQ_MAX_TOKENS = "2048"
GROQ_TIMEOUT = "60"

# ── App (opcional) ──────────────────────────────────────
PUREAURA_APP_NAME = "PureAura"
PUREAURA_APP_VERSION = "1.0.0"
PUREAURA_DEBUG = "false"
